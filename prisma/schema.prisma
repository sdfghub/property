datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

enum SeriesScope {
  UNIT
  GROUP
  COMMUNITY
}

enum SeriesOrigin {
  METER
  DECLARATION
  ADMIN
  DERIVED
}

enum AllocationMethod {
  EQUAL
  BY_SQM
  BY_RESIDENTS
  BY_CONSUMPTION
  MIXED
}

enum DocSource {
  MANUAL
  INTERNAL
  OCR
  IMPORT
  API
}

enum SplitMethod {
  EQUAL
  DAYS
  WEIGHTED_MANUAL
  CUSTOM
}

enum ChargeSourceType {
  EXPENSE
  FUND
  VENDOR_INVOICE
  MANUAL
  TEMPLATE
}

enum CashAccountType {
  BANK
  PETTY
}

enum CashTxDirection {
  IN
  OUT
}

enum CashTxKind {
  PAYMENT
  TRANSFER
  ADJUSTMENT
  OTHER
}

enum CashTxStatus {
  POSTED
  CLEARED
  VOID
}

enum ChargeStatus {
  ACTIVE
  VOID
  REVERSED
}

enum EntityType {
  COMMUNITY
  PERIOD
  UNIT
  GROUP
  BILLING_ENTITY
  SERIES
  EXPENSE
  EXPENSE_TYPE
  VENDOR
  VENDOR_INVOICE
  RULE
  MEASURE_TYPE
}

enum NodeKind {
  COMMUNITY
  GROUP
  UNIT
  SET
}

enum PollStatus {
  DRAFT
  PROPOSED
  APPROVED
  REJECTED
  CLOSED
}

enum TicketType {
  INCIDENT
  TASK
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELED
  REOPENED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketTag {
  OUTAGE
  BREAKDOWN
  LEAK
  SAFETY
  SECURITY
  COMPLAINT
  ACCESS
  NOISE
  CLEANLINESS
  DAMAGE
  PREVENTIVE_MAINTENANCE
  INSPECTION
  REPAIR
  UPGRADE
  CLEANING
  VENDOR_VISIT
  COMPLIANCE
  METER_READING
}

enum TicketEventType {
  STATUS_CHANGE
  COMMENT
  ASSIGNMENT
  TAGS_UPDATED
}

enum AnnouncementAudienceType {
  COMMUNITY
  UNIT_GROUP
}

enum AnnouncementImpactTag {
  WATER
  HEAT
  ELEVATOR
  ELECTRICITY
  ACCESS
  OTHER
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

enum NotificationSource {
  TICKET
  COMMUNICATION
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum InventoryAssetStatus {
  ACTIVE
  INACTIVE
}

model Community {
  id       String @id @map("id")
  code     String
  name     String @map("name")
  timezone String @default("Europe/Bucharest") @map("timezone")
  penaltyGraceDays Int @default(30) @map("penalty_grace_days")
  features Json? @map("features") // per-community feature flags (see FeaturesService defaults)
  paymentAllocation Json? @map("payment_allocation") // per-community payment→charge allocation strategy (see PaymentAllocationService; default FIFO)
  measureModes Json? @map("measure_modes") // per-type meter reading mode { "<typeCode>": "INDEX" | "CONSUMPTION" }; default CONSUMPTION

  periods                    Period[]
  units                      Unit[]
  groups                     UnitGroup[]
  billingEntities            BillingEntity[]
  rules                      AllocationRule[]
  expenseTypes               ExpenseType[]
  periodMeasures             PeriodMeasure[]
  bills                      Bill[]
  vendors                    Vendor[]
  invoices                   VendorInvoice[]
  externalRefs               ExternalRef[]
  MeasureSeries              MeasureSeries[]
  AggregationRule            AggregationRule[]
  DerivedMeterRule           DerivedMeterRule[]
  SplitGroup                 SplitGroup[]
  Fund                       Fund[]
  CommunityCharge            CommunityCharge[]
  CommunityChargeLine        CommunityChargeLine[]
  Payment                    Payment[]
  BillTemplate               BillTemplate[]
  BillTemplateInstance       BillTemplateInstance[]
  MeterEntryTemplate         MeterEntryTemplate[]
  MeterEntryTemplateInstance MeterEntryTemplateInstance[]
  Event                      Event[]
  Poll                       Poll[]
  tickets                    Ticket[]
  announcements              Announcement[]
  inventoryAssets            InventoryAsset[]
  VendorPayment              VendorPayment[]
  CashAccount                CashAccount[]
  CashTx                     CashTx[]

  @@map("community")
}

enum PeriodStatus {
  DRAFT
  OPEN
  PREPARED
  CLOSED
}

model Period {
  id          String       @id @default(cuid()) @map("id")
  communityId String       @map("community_id")
  code        String       @map("code")
  startDate   DateTime     @map("start_date")
  endDate     DateTime     @map("end_date")
  dueDate     DateTime?    @map("due_date")
  seq         Int          @map("seq")
  timezone    String       @default("Europe/Bucharest") @map("timezone")
  status      PeriodStatus @default(OPEN)
  preparedAt  DateTime?    @map("prepared_at")
  closedAt    DateTime?    @map("closed_at")

  community                  Community                    @relation(fields: [communityId], references: [id])
  PeriodMeasure              PeriodMeasure[]
  Bill                       Bill[]
  InvoiceSplit               InvoiceSplit[]
  BillTemplateInstance       BillTemplateInstance[]
  MeterEntryTemplateInstance MeterEntryTemplateInstance[]
  CommunityCharge            CommunityCharge[]
  CommunityChargeLine        CommunityChargeLine[]

  @@unique([communityId, code])
  @@unique([communityId, seq])
  @@index([communityId, startDate, endDate])
  @@map("period")
}

model Unit {
  id          String @id @default(cuid()) @map("id")
  communityId String @map("community_id")
  code        String @map("code")
  order       Int    @default(0) @map("order")

  community           Community             @relation(fields: [communityId], references: [id])
  UnitGroupMember     UnitGroupMember[]
  BillingEntityMember BillingEntityMember[]
  BeLedgerEntryDetail BeLedgerEntryDetail[]
  CommunityChargeLine CommunityChargeLine[]
  BeOpeningBalance     BeOpeningBalance[]

  @@unique([code, communityId])
  @@index([communityId])
  @@map("unit")
}

model UnitGroup {
  id          String @id @default(cuid()) @map("id")
  communityId String @map("community_id")
  code        String @map("code")
  name        String @map("name")

  community                  Community                   @relation(fields: [communityId], references: [id])
  members                    UnitGroupMember[]
  announcementAudienceGroups AnnouncementAudienceGroup[]

  @@unique([code, communityId])
  @@index([communityId])
  @@map("unit_group")
}

model UnitGroupMember {
  id            String  @id @default(cuid()) @map("id")
  groupId       String  @map("group_id")
  unitId        String  @map("unit_id")
  startPeriodId String  @map("start_period_id")
  endPeriodId   String? @map("end_period_id")
  startSeq      Int     @map("start_seq")
  endSeq        Int?    @map("end_seq")

  group UnitGroup @relation(fields: [groupId], references: [id])
  unit  Unit      @relation(fields: [unitId], references: [id])

  @@index([groupId, startSeq, endSeq])
  @@index([unitId, startSeq, endSeq])
  @@map("unit_group_member")
}

model BillingEntity {
  id          String @id @default(cuid()) @map("id")
  communityId String @map("community_id")
  code        String @map("code")
  order       Int    @default(0) @map("order")
  name        String @map("name")

  community Community               @relation(fields: [communityId], references: [id])
  members   BillingEntityMember[]
  userRoles BillingEntityUserRole[]
  bills     Bill[]
  Payment   Payment[]
  CommunityChargeLine CommunityChargeLine[]

  @@unique([code, communityId])
  @@index([communityId])
  @@map("billing_entity")
}

model BillingEntityMember {
  id              String  @id @default(cuid()) @map("id")
  billingEntityId String  @map("billing_entity_id")
  unitId          String  @map("unit_id")
  startPeriodId   String  @map("start_period_id")
  endPeriodId     String? @map("end_period_id")
  startSeq        Int     @map("start_seq")
  endSeq          Int?    @map("end_seq")

  billingEntity BillingEntity @relation(fields: [billingEntityId], references: [id])
  unit          Unit          @relation(fields: [unitId], references: [id])

  @@index([billingEntityId, startSeq, endSeq])
  @@index([unitId, startSeq, endSeq])
  @@map("billing_entity_member")
}

enum BillingEntityRole {
  OWNER
  RESIDENT
  EXPENSE_RESPONSIBLE
}

model BillingEntityUserRole {
  id              String            @id @default(cuid()) @map("id")
  billingEntityId String            @map("billing_entity_id")
  userId          String            @map("user_id")
  role            BillingEntityRole @map("role")
  createdAt       DateTime          @default(now()) @map("created_at")

  billingEntity BillingEntity @relation(fields: [billingEntityId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@unique([billingEntityId, userId, role])
  @@index([userId])
  @@index([billingEntityId])
  @@map("billing_entity_user_role")
}

model MeasureType {
  code   String          @id @map("code")
  name   String?         @map("name")
  unit   String          @map("unit")
  series MeasureSeries[]

  @@map("measure_type")
}

model MeasureSeries {
  id          String       @id @default(cuid()) @map("id")
  communityId String       @map("community_id")
  scope       SeriesScope  @map("scope")
  scopeId     String       @map("scope_id")
  typeCode    String       @map("type_code")
  origin      SeriesOrigin @map("origin")

  community    Community            @relation(fields: [communityId], references: [id])
  type         MeasureType          @relation(fields: [typeCode], references: [code])
  samples      MeasureSample[]
  periodValues MeasurePeriodValue[]

  @@index([communityId, scope, scopeId, typeCode])
  @@map("measure_series")
}

model MeasureSample {
  id        String   @id @default(cuid()) @map("id")
  seriesId  String   @map("series_id")
  ts        DateTime @map("ts")
  value     Decimal  @map("value") @db.Decimal(18, 6)
  estimated Boolean  @default(false) @map("estimated")

  series MeasureSeries @relation(fields: [seriesId], references: [id])

  @@index([seriesId, ts])
  @@map("measure_sample")
}

model MeasurePeriodValue {
  id            String  @id @default(cuid()) @map("id")
  seriesId      String  @map("series_id")
  startPeriodId String  @map("start_period_id")
  endPeriodId   String? @map("end_period_id")
  startSeq      Int     @map("start_seq")
  endSeq        Int?    @map("end_seq")
  value         Decimal @map("value") @db.Decimal(18, 6)

  series MeasureSeries @relation(fields: [seriesId], references: [id])

  @@index([seriesId, startSeq, endSeq])
  @@map("measure_period_value")
}

model PeriodMeasure {
  id          String       @id @default(cuid()) @map("id")
  communityId String       @map("community_id")
  periodId    String       @map("period_id")
  meterId     String       @map("meter_id")
  scopeType   SeriesScope  @map("scope_type")
  scopeId     String       @map("scope_id")
  typeCode    String       @map("type_code")
  origin      SeriesOrigin @map("origin")
  value       Decimal      @map("value") @db.Decimal(18, 6) // period consumption (derived when INDEX mode)
  reading     Decimal?     @map("reading") @db.Decimal(18, 6) // raw cumulative meter index (INDEX mode only)
  estimated   Boolean      @default(false) @map("estimated")
  enteredById String?      @map("entered_by_id") // user who entered this value (null for derived/aggregation)
  selfReported Boolean     @default(false) @map("self_reported") // true when entered by a non-admin (e.g. resident)
  provenance  Json?        @map("provenance")

  community Community @relation(fields: [communityId], references: [id])
  period    Period    @relation(fields: [periodId], references: [id])
  enteredBy User?     @relation("MeasureEnteredBy", fields: [enteredById], references: [id])

  @@unique([communityId, periodId, scopeType, scopeId, typeCode])
  @@index([meterId])
  @@index([periodId, typeCode])
  @@map("period_measure")
}

model AllocationRule {
  id          String           @id @default(cuid()) @map("id")
  communityId String           @map("community_id")
  method      AllocationMethod @map("method")
  name        String?          @map("name")
  params      Json?            @map("params")

  community    Community      @relation(fields: [communityId], references: [id])
  expenseTypes ExpenseType[]

  @@map("allocation_rule")
}

model ExpenseType {
  id          String  @id @default(cuid()) @map("id")
  communityId String  @map("community_id")
  code        String  @map("code")
  name        String  @map("name")
  ruleId      String  @map("rule_id")
  params      Json?   @map("params")
  currency    String? @map("currency")

  community Community      @relation(fields: [communityId], references: [id])
  rule      AllocationRule @relation(fields: [ruleId], references: [id])

  @@unique([code, communityId])
  @@map("expense_type")
}

model CommunityCharge {
  id          String           @id @default(cuid()) @map("id")
  communityId String           @map("community_id")
  periodId    String           @map("period_id")
  fundId      String?          @map("fund_id")
  sourceType  ChargeSourceType @map("source_type")
  sourceId    String           @map("source_id")
  sourceKey   String?          @map("source_key")
  amount      Decimal          @map("amount") @db.Decimal(18, 4)
  currency    String           @default("RON") @map("currency")
  allocationStrategy  String? @map("allocation_strategy")
  allocationSnapshot  Json?   @map("allocation_snapshot")
  status      ChargeStatus     @default(ACTIVE) @map("status")
  meta        Json?            @map("meta")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  period    Period    @relation(fields: [periodId], references: [id])
  fund      Fund?     @relation(fields: [fundId], references: [id])
  lines     CommunityChargeLine[]

  @@unique([communityId, periodId, sourceType, sourceId, sourceKey, fundId])
  @@index([communityId, periodId])
  @@index([fundId])
  @@map("community_charge")
}

model CommunityChargeLine {
  id              String   @id @default(cuid()) @map("id")
  chargeId        String   @map("charge_id")
  communityId     String   @map("community_id")
  periodId        String   @map("period_id")
  billingEntityId String   @map("billing_entity_id")
  unitId          String   @map("unit_id")
  amount          Decimal  @map("amount") @db.Decimal(18, 4)
  meta            Json?    @map("meta")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  charge        CommunityCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  community     Community       @relation(fields: [communityId], references: [id])
  period        Period          @relation(fields: [periodId], references: [id])
  billingEntity BillingEntity   @relation(fields: [billingEntityId], references: [id])
  unit          Unit            @relation(fields: [unitId], references: [id])
  billLines     BillLine[]

  @@index([communityId, periodId])
  @@index([chargeId])
  @@index([billingEntityId])
  @@index([unitId])
  @@map("community_charge_line")
}

model SplitGroup {
  id          String @id @default(cuid()) @map("id")
  communityId String @map("community_id")
  code        String @map("code")
  name        String @map("name")
  order       Int?   @map("order")

  community Community          @relation(fields: [communityId], references: [id])
  members   SplitGroupMember[]

  @@unique([communityId, code])
  @@index([communityId])
  @@map("split_group")
}

model SplitGroupMember {
  id           String @id @default(cuid()) @map("id")
  splitGroupId String @map("split_group_id")
  splitNodeId  String @map("split_node_id")

  splitGroup SplitGroup @relation(fields: [splitGroupId], references: [id])

  @@unique([splitGroupId, splitNodeId])
  @@index([splitNodeId])
  @@map("split_group_member")
}

model CashAccount {
  id          String           @id @default(cuid()) @map("id")
  communityId String           @map("community_id")
  code        String           @map("code")
  name        String           @map("name")
  type        CashAccountType  @map("type")
  currency    String           @default("RON") @map("currency")
  status      String           @default("ACTIVE") @map("status")
  notes       Json?            @map("notes")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  CashTx    CashTx[]
  Payment   Payment[]
  VendorPayment VendorPayment[]

  @@unique([communityId, code])
  @@index([communityId])
  @@map("cash_account")
}

model Fund {
  id              String   @id @default(cuid()) @map("id")
  communityId     String   @map("community_id")
  code            String   @map("code")
  name            String   @map("name")
  description     String?  @map("description")
  status          String   @default("PLANNED") @map("status")
  currency        String   @default("RON") @map("currency")
  totalTarget     Decimal? @map("total_target") @db.Decimal(18, 2)
  startPeriodCode String?  @map("start_period_code")
  targetPlan      Json?    @map("target_plan")
  targets         Json?    @map("targets")
  allocation      Json?    @map("allocation")

  community             Community               @relation(fields: [communityId], references: [id])
  fundInvoices          FundInvoice[]
  FundLedgerEntryDetail FundLedgerEntryDetail[]
  FundLedgerEntry       FundLedgerEntry[]
  CommunityCharge       CommunityCharge[]
  BeLedgerEntry         BeLedgerEntry[]
  BeLedgerEntryDetail   BeLedgerEntryDetail[]
  BeOpeningBalance      BeOpeningBalance[]
  CashTx               CashTx[]

  @@unique([communityId, code])
  @@index([communityId])
  @@map("fund")
}

model Event {
  id              String   @id @default(cuid()) @map("id")
  communityId     String   @map("community_id")
  title           String   @map("title")
  description     String?  @map("description")
  startAt         DateTime @map("start_at")
  endAt           DateTime @map("end_at")
  location        String?  @map("location")
  attachments     Json?    @map("attachments")
  visibility      String   @default("COMMUNITY") @map("visibility")
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  community Community   @relation(fields: [communityId], references: [id])
  createdBy User        @relation(fields: [createdByUserId], references: [id])
  rsvps     EventRsvp[]

  @@index([communityId, startAt])
  @@map("event")
}

model EventRsvp {
  id        String   @id @default(cuid()) @map("id")
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  status    String   @map("status") // 'GOING' | 'NOT_GOING'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_rsvp")
}

model Poll {
  id                 String     @id @default(cuid()) @map("id")
  communityId        String     @map("community_id")
  title              String     @map("title")
  description        String?    @map("description")
  status             PollStatus @default(DRAFT) @map("status")
  allowsMultiple     Boolean    @default(false) @map("allows_multiple")
  anonymized         Boolean    @default(false) @map("anonymized")
  startAt            DateTime   @map("start_at")
  endAt              DateTime   @map("end_at")
  publishedResultsAt DateTime?  @map("published_results_at")
  createdByUserId    String     @map("created_by_user_id")
  approvedByUserId   String?    @map("approved_by_user_id")
  rejectedByUserId   String?    @map("rejected_by_user_id")
  rejectionReason    String?    @map("rejection_reason")
  approvedAt         DateTime?  @map("approved_at")
  rejectedAt         DateTime?  @map("rejected_at")
  closedAt           DateTime?  @map("closed_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  community  Community    @relation(fields: [communityId], references: [id])
  createdBy  User         @relation("PollCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy User?        @relation("PollApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy User?        @relation("PollRejectedBy", fields: [rejectedByUserId], references: [id])
  options    PollOption[]
  votes      PollVote[]
  voters     PollVoter[]

  @@index([communityId, status])
  @@index([communityId, startAt, endAt])
  @@map("poll")
}

model PollOption {
  id     String @id @default(cuid()) @map("id")
  pollId String @map("poll_id")
  text   String @map("text")
  order  Int    @default(0) @map("order")

  poll  Poll       @relation(fields: [pollId], references: [id])
  votes PollVote[]

  @@unique([pollId, text])
  @@index([pollId])
  @@map("poll_option")
}

model PollVote {
  id           String   @id @default(cuid()) @map("id")
  pollId       String   @map("poll_id")
  pollOptionId String   @map("poll_option_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  poll   Poll       @relation(fields: [pollId], references: [id])
  option PollOption @relation(fields: [pollOptionId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@unique([pollId, userId, pollOptionId])
  @@index([pollId, userId])
  @@index([pollOptionId])
  @@map("poll_vote")
}

model PollVoter {
  id        String   @id @default(cuid()) @map("id")
  pollId    String   @map("poll_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  poll Poll @relation(fields: [pollId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@index([pollId])
  @@map("poll_voter")
}

model AggregationRule {
  id           String  @id @default(cuid()) @map("id")
  communityId  String  @map("community_id")
  targetType   String  @map("target_type")
  unitTypes    Json    @map("unit_types")
  residualType String? @map("residual_type")
  totalType    String? @map("total_type")

  community Community @relation(fields: [communityId], references: [id])

  @@unique([communityId, targetType])
  @@index([communityId])
  @@map("aggregation_rule")
}

model DerivedMeterRule {
  id            String       @id @default(cuid()) @map("id")
  communityId   String       @map("community_id")
  scopeType     SeriesScope  @default(COMMUNITY) @map("scope_type")
  sourceType    String       @map("source_type")
  subtractTypes Json         @map("subtract_types")
  targetType    String       @map("target_type")
  origin        SeriesOrigin @default(DERIVED) @map("origin")

  community Community @relation(fields: [communityId], references: [id])

  @@unique([communityId, scopeType, sourceType, targetType])
  @@index([communityId])
  @@map("derived_meter_rule")
}

model Meter {
  meterId     String    @id @map("meter_id")
  name        String?   @map("name")
  scopeType   String    @map("scope_type")
  scopeCode   String    @map("scope_code")
  typeCode    String    @map("type_code")
  origin      String    @default("METER") @map("origin")
  installedAt DateTime? @map("installed_at")
  retiredAt   DateTime? @map("retired_at")
  multiplier  Decimal?  @map("multiplier") @db.Decimal(18, 6)
  openingIndex Decimal? @map("opening_index") @db.Decimal(18, 6) // optional baseline for INDEX-mode meters
  notes       String?   @map("notes")

  @@index([scopeCode])
  @@index([typeCode])
  @@map("meter")
}

model Bill {
  id              String  @id @default(cuid()) @map("id")
  communityId     String  @map("community_id")
  periodId        String  @map("period_id")
  billingEntityId String  @map("billing_entity_id")
  totalAmount     Decimal @map("total_amount") @db.Decimal(18, 4)

  community     Community     @relation(fields: [communityId], references: [id])
  period        Period        @relation(fields: [periodId], references: [id])
  billingEntity BillingEntity @relation(fields: [billingEntityId], references: [id])
  lines         BillLine[]

  @@unique([communityId, periodId, billingEntityId])
  @@map("bill")
}

model BillLine {
  id           String  @id @default(cuid()) @map("id")
  billId       String  @map("bill_id")
  chargeLineId String  @map("charge_line_id")
  amount       Decimal @map("amount") @db.Decimal(18, 4)
  meta         Json?   @map("meta")

  bill       Bill                @relation(fields: [billId], references: [id])
  chargeLine CommunityChargeLine @relation(fields: [chargeLineId], references: [id])

  @@index([billId])
  @@index([chargeLineId])
  @@map("bill_line")
}

model Vendor {
  id          String  @id @default(cuid()) @map("id")
  communityId String  @map("community_id")
  name        String  @map("name")
  taxId       String? @map("tax_id")
  iban        String? @map("iban")

  community     Community       @relation(fields: [communityId], references: [id])
  VendorInvoice VendorInvoice[]
  VendorPayment VendorPayment[]

  @@unique([communityId, name])
  @@map("vendor")
}

model VendorInvoice {
  id                   String    @id @default(cuid()) @map("id")
  communityId          String    @map("community_id")
  vendorId             String?   @map("vendor_id")
  templateInstanceId   String?   @map("template_instance_id")
  number               String?   @map("number")
  issueDate            DateTime? @map("issue_date")
  dueDate              DateTime? @map("due_date")
  serviceStartPeriodId String?   @map("service_start_period_id")
  serviceEndPeriodId   String?   @map("service_end_period_id")
  currency             String    @default("RON") @map("currency")
  net                  Decimal?  @map("net") @db.Decimal(18, 4)
  vat                  Decimal?  @map("vat") @db.Decimal(18, 4)
  gross                Decimal?  @map("gross") @db.Decimal(18, 4)
  source               DocSource @default(MANUAL) @map("source")
  hash                 String?   @map("hash")
  provenance           Json?     @map("provenance")

  community    Community          @relation(fields: [communityId], references: [id])
  vendor       Vendor?            @relation(fields: [vendorId], references: [id])
  templateInstance BillTemplateInstance? @relation(fields: [templateInstanceId], references: [id])
  docs         VendorInvoiceDoc[]
  splits       InvoiceSplit[]
  fundInvoices FundInvoice[]
  payments     VendorPayment[]
  paymentApplications VendorPaymentApplication[]

  @@index([communityId, number])
  @@unique([templateInstanceId])
  @@map("vendor_invoice")
}

model VendorPayment {
  id          String   @id @default(cuid()) @map("id")
  communityId String   @map("community_id")
  vendorId    String?  @map("vendor_id")
  invoiceId   String   @map("invoice_id")
  accountId   String?  @map("account_id")
  amount      Decimal  @map("amount") @db.Decimal(18, 4)
  currency    String   @default("RON") @map("currency")
  ts          DateTime @default(now()) @map("ts")
  method      String?  @map("method")
  refId       String?  @map("ref_id")
  status      String   @default("POSTED") @map("status")

  community Community     @relation(fields: [communityId], references: [id])
  vendor    Vendor?       @relation(fields: [vendorId], references: [id])
  invoice   VendorInvoice @relation(fields: [invoiceId], references: [id])
  account   CashAccount?  @relation(fields: [accountId], references: [id])
  applications VendorPaymentApplication[]

  @@index([communityId])
  @@index([invoiceId])
  @@index([vendorId])
  @@index([accountId])
  @@index([status], map: "vendor_payment_status_idx")
  @@map("vendor_payment")
}

model VendorPaymentApplication {
  id        String   @id @default(cuid()) @map("id")
  paymentId String   @map("payment_id")
  invoiceId String   @map("invoice_id")
  amount    Decimal  @map("amount") @db.Decimal(18, 4)
  spec      Json?    @map("spec")
  createdAt DateTime @default(now()) @map("created_at")

  payment VendorPayment @relation(fields: [paymentId], references: [id])
  invoice VendorInvoice @relation(fields: [invoiceId], references: [id])

