  refId       String?  @map("ref_id")
  createdAt   DateTime @default(now()) @map("created_at")

  details FundLedgerEntryDetail[]
  fund    Fund                    @relation(fields: [fundId], references: [id])

  @@unique([communityId, fundId, periodId, refType, refId, kind])
  @@index([communityId, fundId, periodId])
  @@index([communityId, fundId])
  @@index([communityId, fundId, lane])
  @@map("fund_ledger_entry")
}

model User {
  id                      String                     @id @default(cuid())
  email                   String                     @unique
  name                    String?
  passwordHash            String?                    @map("password_hash")
  createdAt               DateTime                   @default(now()) @map("created_at")
  tokenVersion            Int                        @default(0) @map("token_version")
  roles                   RoleAssignment[]
  billingEntityRoles      BillingEntityUserRole[]
  invites                 Invite[]
  refreshTokens           RefreshToken[]
  oauthAccounts           UserOAuthAccount[]
  pushTokens              PushToken[]
  eventsCreated           Event[]
  pollsCreated            Poll[]                     @relation("PollCreatedBy")
  pollsApproved           Poll[]                     @relation("PollApprovedBy")
  pollsRejected           Poll[]                     @relation("PollRejectedBy")
  pollVotes               PollVote[]
  pollVoters              PollVoter[]
  eventRsvps              EventRsvp[]
  ticketsCreated          Ticket[]                   @relation("TicketCreatedBy")
  ticketsAssigned         Ticket[]                   @relation("TicketAssignee")
  ticketEvents            TicketEvent[]
  enteredMeasures         PeriodMeasure[]            @relation("MeasureEnteredBy")
  announcementsCreated    Announcement[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  inventoryAssetsCreated  InventoryAsset[]
  inventoryRulesCreated   InventoryMaintenanceRule[]

  @@map("user")
}

enum OAuthProvider {
  GOOGLE
  APPLE
  FACEBOOK
  MICROSOFT
}

model UserOAuthAccount {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  email          String?
  createdAt      DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([email])
  @@map("user_oauth_account")
}

enum Role {
  SYSTEM_ADMIN
  COMMUNITY_ADMIN
  CENSOR
  EXECUTIVE_COMITEE_MEMBER
  BILLING_ENTITY_USER
}

enum ScopeType {
  SYSTEM
  COMMUNITY
  BILLING_ENTITY
}

enum CommitteeDecisionStatus {
  OPEN
  APPROVED
  REJECTED
  CANCELLED
}

enum CommitteeVoteValue {
  APPROVE
  REJECT
}

/// Free-form governance proposal raised by the admin; approved by a majority of the community's committee members.
model CommitteeDecision {
  id          String                  @id @default(cuid())
  communityId String                  @map("community_id") // community code, matching app-wide convention
  title       String
  description String?
  amount      Decimal?                @db.Decimal(18, 4)
  currency    String                  @default("RON")
  status      CommitteeDecisionStatus @default(OPEN)
  createdBy   String                  @map("created_by")
  decidedAt   DateTime?               @map("decided_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  votes       CommitteeVote[]

  @@index([communityId, status])
  @@map("committee_decision")
}

model CommitteeVote {
  id         String             @id @default(cuid())
  decisionId String             @map("decision_id")
  userId     String             @map("user_id")
  vote       CommitteeVoteValue
  comment    String?
  createdAt  DateTime           @default(now()) @map("created_at")
  decision   CommitteeDecision  @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@unique([decisionId, userId])
  @@map("committee_vote")
}

model RoleAssignment {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  role      Role
  scopeType ScopeType @map("scope_type")
  scopeId   String?
  createAt  DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, role, scopeType, scopeId])
  @@map("role_assignment")
}

model Invite {
  id         String              @id @default(cuid())
  email      String
  role       Role
  userId     String?             @map("user_id")
  beRoles    BillingEntityRole[] @default([]) @map("be_roles")
  scopeType  ScopeType           @map("scope_type")
  scopeId    String?             @map("scope_id")
  invitedBy  String              @map("invited_by")
  token      String              @unique
  expiresAt  DateTime            @map("expires_at")
  acceptedAt DateTime?           @map("accepted_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  user       User?               @relation(fields: [userId], references: [id])

  @@map("invite")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  jti       String    @unique
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_token")
}

model PushToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  token      String    @unique
  platform   String    @default("WEB")
  deviceInfo Json?     @map("device_info")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@map("push_token")
}

model Ticket {
  id                    String         @id @default(cuid())
  communityId           String         @map("community_id")
  type                  TicketType
  status                TicketStatus   @default(NEW)
  priority              TicketPriority @default(MEDIUM)
  title                 String
  description           String?
  createdById           String         @map("created_by_id")
  assigneeId            String?        @map("assignee_id")
  sourceInventoryRuleId String?        @map("source_inventory_rule_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  community           Community                 @relation(fields: [communityId], references: [id])
  createdBy           User                      @relation("TicketCreatedBy", fields: [createdById], references: [id])
  assignee            User?                     @relation("TicketAssignee", fields: [assigneeId], references: [id])
  sourceInventoryRule InventoryMaintenanceRule? @relation(fields: [sourceInventoryRuleId], references: [id])
  tags                TicketTagMap[]
  events              TicketEvent[]

  @@index([communityId, status])
  @@index([createdById])
  @@index([assigneeId])
  @@index([sourceInventoryRuleId])
  @@map("ticket")
}

model TicketTagMap {
  id       String    @id @default(cuid())
  ticketId String    @map("ticket_id")
  tag      TicketTag

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@unique([ticketId, tag])
  @@index([tag])
  @@map("ticket_tag")
}

model TicketEvent {
  id        String          @id @default(cuid())
  ticketId  String          @map("ticket_id")
  actorId   String          @map("actor_id")
  type      TicketEventType
  comment   String?
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])
  actor  User   @relation(fields: [actorId], references: [id])

  @@index([ticketId])
  @@map("ticket_event")
}

model Announcement {
  id           String                   @id @default(cuid())
  communityId  String                   @map("community_id")
  title        String
  body         String
  startsAt     DateTime?                @map("starts_at")
  endsAt       DateTime?                @map("ends_at")
  audienceType AnnouncementAudienceType @map("audience_type")
  createdById  String                   @map("created_by_id")
  createdAt    DateTime                 @default(now()) @map("created_at")

  community      Community                   @relation(fields: [communityId], references: [id])
  createdBy      User                        @relation(fields: [createdById], references: [id])
  impactTags     AnnouncementImpactTagMap[]
  audienceGroups AnnouncementAudienceGroup[]
  targetRoles    AnnouncementTargetRole[]

  @@index([communityId])
  @@map("announcement")
}

model AnnouncementImpactTagMap {
  id             String                @id @default(cuid())
  announcementId String                @map("announcement_id")
  tag            AnnouncementImpactTag

  announcement Announcement @relation(fields: [announcementId], references: [id])

  @@unique([announcementId, tag])
  @@map("announcement_impact_tag")
}

model AnnouncementAudienceGroup {
  id             String @id @default(cuid())
  announcementId String @map("announcement_id")
  unitGroupId    String @map("unit_group_id")

  announcement Announcement @relation(fields: [announcementId], references: [id])
  unitGroup    UnitGroup    @relation(fields: [unitGroupId], references: [id])

  @@unique([announcementId, unitGroupId])
  @@index([unitGroupId])
  @@map("announcement_audience_group")
}

model AnnouncementTargetRole {
  id             String            @id @default(cuid())
  announcementId String            @map("announcement_id")
  role           BillingEntityRole @map("role")

  announcement Announcement @relation(fields: [announcementId], references: [id])

  @@unique([announcementId, role])
  @@index([announcementId])
  @@map("announcement_target_role")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  source    NotificationSource
  sourceId  String?            @map("source_id")
  title     String
  body      String
  data      Json?
  readAt    DateTime?          @map("read_at")
  createdAt DateTime           @default(now()) @map("created_at")

  user       User                   @relation(fields: [userId], references: [id])
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@map("notification")
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, channel])
  @@map("notification_preference")
}

model NotificationDelivery {
  id             String                     @id @default(cuid())
  notificationId String                     @map("notification_id")
  channel        NotificationChannel
  status         NotificationDeliveryStatus @default(PENDING)
  error          String?
  sentAt         DateTime?                  @map("sent_at")
  createdAt      DateTime                   @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@map("notification_delivery")
}

model InventoryAsset {
  id          String               @id @default(cuid())
  communityId String               @map("community_id")
  name        String
  description String?
  status      InventoryAssetStatus @default(ACTIVE)
  metadata    Json?
  createdById String               @map("created_by_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  community Community                  @relation(fields: [communityId], references: [id])
  createdBy User                       @relation(fields: [createdById], references: [id])
  rules     InventoryMaintenanceRule[]

  @@index([communityId])
  @@map("inventory_asset")
}

model InventoryMaintenanceRule {
  id           String   @id @default(cuid())
  assetId      String   @map("asset_id")
  title        String
  description  String?
  intervalDays Int      @map("interval_days")
  nextDueAt    DateTime @map("next_due_at")
  enabled      Boolean  @default(true)
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  asset     InventoryAsset        @relation(fields: [assetId], references: [id])
  createdBy User                  @relation(fields: [createdById], references: [id])
  tags      InventoryRuleTagMap[]
  tickets   Ticket[]

  @@index([assetId, enabled])
  @@index([nextDueAt])
  @@map("inventory_maintenance_rule")
}

model InventoryRuleTagMap {
  id     String    @id @default(cuid())
  ruleId String    @map("rule_id")
  tag    TicketTag

  rule InventoryMaintenanceRule @relation(fields: [ruleId], references: [id])

  @@unique([ruleId, tag])
  @@map("inventory_rule_tag")
}
