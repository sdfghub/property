// ---------- Opening balance per BE & period ----------
model BeOpeningBalance {
  id              String   @id @default(cuid()) @map("id")
  communityId     String   @map("community_id")
  periodId        String   @map("period_id")
  billingEntityId String   @map("billing_entity_id")
  fundId          String?  @map("fund_id")
  unitId          String?  @map("unit_id")
  amount          Decimal  @default(0) @map("amount")
  currency        String   @default("RON") @map("currency")
  // Aging support for migrated arrears: kind separates carried principal vs penalty; dueDate is the
  // bucket's scadență (null => treat as already past-due); originKey makes multiple aged buckets per
  // (unit,fund) uniquely keyable (non-null, e.g. an origin period code, "TOTAL", or "PEN:<srcFund>").
  dueDate         DateTime? @map("due_date")
  kind            String   @default("PRINCIPAL") @map("kind")
  originKey       String   @default("TOTAL") @map("origin_key")
  createdAt       DateTime @default(now()) @map("created_at")

  fund Fund? @relation(fields: [fundId], references: [id])
  unit Unit? @relation(fields: [unitId], references: [id])

  @@unique([communityId, periodId, billingEntityId, fundId, unitId, kind, originKey])
  @@index([communityId, fundId])
  @@index([communityId, unitId])
  @@map("be_opening_balance")
}

// ---------- Stateful penalty aging ledger ----------
// One durable bucket per penalizable due (a period charge, or a migrated PRINCIPAL opening).
// Penalty is a path-dependent accrual: each period advances the bucket from its last committed
// state (see PenaltyBucketPeriod), never re-derived from aggregates.
model PenaltyBucket {
  id                String   @id @default(cuid())
  communityId       String   @map("community_id")
  billingEntityId   String   @map("billing_entity_id")
  fundId            String   @map("fund_id")          // source fund whose principal this is
  targetFundId      String   @map("target_fund_id")   // resolved penaltyFundCode (earmark)
  originKey         String   @map("origin_key")       // 'period:<periodId>' | migrated opening originKey
  dueDate           DateTime? @map("due_date")        // scadență (null => already past-due)
  firstPenalDay     DateTime @map("first_penal_day")  // dueDate + graceDays + 1
  principalOriginal Decimal  @map("principal_original") // cap base
  seedPenaltyAccrued Decimal @default(0) @map("seed_penalty_accrued") // carried penalty at cutover (cap headroom baseline)
  ratePerDayPct     Decimal? @map("rate_per_day_pct") // penalty %/day stamped at bucket creation; null => use the fund's current rate
  status            String   @default("OPEN") @map("status") // OPEN | SETTLED
  createdAt         DateTime @default(now()) @map("created_at")

  periods PenaltyBucketPeriod[]

  @@unique([communityId, billingEntityId, fundId, originKey])
  @@index([communityId, status])
  @@map("penalty_bucket")
}

// One row per period a bucket is advanced — the committed (frozen-at-close) state + audit trail.
// Committed state of a bucket = its highest periodSeq row with status COMMITTED.
model PenaltyBucketPeriod {
  id                 String   @id @default(cuid())
  bucketId           String   @map("bucket_id")
  periodId           String   @map("period_id")
  periodSeq          Int      @map("period_seq")
  principalRemaining Decimal  @map("principal_remaining")
  penaltyAccrued     Decimal  @map("penalty_accrued")   // cumulative on this bucket through this period
  penaltyPosted      Decimal  @map("penalty_posted")    // increment charged this period
  status             String   @default("PROVISIONAL") @map("status") // PROVISIONAL | COMMITTED
  createdAt          DateTime @default(now()) @map("created_at")

  bucket PenaltyBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@unique([bucketId, periodId])
  @@index([bucketId, periodSeq])
  @@map("penalty_bucket_period")
}

