# Local Postgres from docker-compose.yml is published on host port 5540 (5432 is taken by
# another local project).
DATABASE_URL="postgresql://postgres:postgres@localhost:5540/property_expenses?schema=public"
PORT=3100
NODE_ENV=development
# Allowed browser origins (Vite web on :5173, Expo on :8081).
APP_ORIGIN=http://localhost:5173,http://localhost:8081
