# Production environment for deploy/docker-compose.yml.
# Copy to deploy/.env and fill in. NEVER commit the real .env (it is gitignored).

# ---- Database ----
# Postgres superuser password (used by the db container and the api DATABASE_URL).
DB_PASSWORD=change-me-strong-random

# ---- Auth (JWT) ----
# Generate each with:  openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-64-hex
JWT_REFRESH_SECRET=change-me-64-hex

# ---- CORS / public URL ----
# Comma-separated allowed browser origins (include your domain + any LAN/IP you test from).
CORS_ORIGINS=https://your-domain.tld,https://www.your-domain.tld,http://localhost
# Base URL used to build invite links inside emails. Must be the public site.
APP_PUBLIC_URL=https://your-domain.tld

# ---- Admin seed (used by `npm run seed`; see README) ----
# Root admin password. Email defaults to ROOT_EMAIL (bogdan.boji@gmail.com) unless overridden.
ADMIN_PASSWORD=change-me

# ---- Email (SMTP relay) ----
# MailService prefers SMTP when SMTP_HOST is set (falls back to Resend, then dev-log).
# Residential/self-hosted IPs can't send direct mail — use a relay (Gmail app password, Brevo, etc.).
MAIL_FROM=Your Association <noreply@your-domain.tld>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465 (implicit TLS); false for 587 (STARTTLS)
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-or-app-password
