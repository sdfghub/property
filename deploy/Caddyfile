:80 {
	root * /srv
	encode gzip

	@api path /api/*
	handle @api {
		reverse_proxy api:3000
	}

	# Content-hashed build assets — safe to cache forever.
	@assets path /assets/*
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# SPA shell + everything else — never stale-cache index.html, so browsers
	# pick up new builds automatically after each deploy.
	handle {
		try_files {path} /index.html
		header Cache-Control "no-cache"
		file_server
	}
}
